#!/bin/bash

ip address add 10.0.1.1/30 dev eth0	# to t2swisscom
ip address add 10.0.2.1/30 dev eth1	# to t2switch
ip address add 10.0.3.1/30 dev eth2	# to t2sunrise

# append the ruleset to the config file
cat /shared/ruleset.conf >> /etc/frr/frr.conf

systemctl start frr

sleep 5 && vtysh -c "show ip bgp"