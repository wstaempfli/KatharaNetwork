#!/bin/bash

ip address add 10.0.7.2/30 dev eth0		# to t2switch
ip address add 10.0.8.2/30 dev eth1		# to t2sunrise
ip address add 10.0.103.1/24 dev eth2	# local network of t3zkb

# append the ruleset to the config file
cat /shared/ruleset.conf >> /etc/frr/frr.conf

systemctl start frr

sleep 5 && vtysh -c "show ip bgp"