#!/bin/bash

ip address add 10.0.12.1/24 dev eth0
ip address add 10.0.13.1/24 dev eth1
ip address add 10.0.101.1/24 dev eth2

systemctl start scion-dispatcher.service
systemctl start scion-router.service
systemctl start scion-control.service
systemctl start scion-daemon.service
## TODO-01: Start SCION IP Gateway
systemctl start scion-ip-gateway.service
systemctl status scion-*.service
