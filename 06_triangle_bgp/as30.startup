#!/bin/bash

ip address add 10.0.13.3/24 dev eth0	# to AS10
ip address add 10.0.23.3/24 dev eth1	# to AS30
ip address add 10.0.103.1/24 dev eth2	# our AS

####### DO NOT TOUCH THE FOLLOWING LINE #######
tc qdisc add dev eth0 root netem delay 50ms 5ms

systemctl start frr

sleep 5 && vtysh -c "show ip bgp"